{
  "tests": [
    {
      "name": "Get status without auth",
      "method": "GET",
      "path": "/?action=get_status",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get materials ground 1 (public)",
      "method": "GET",
      "path": "/?action=get_materials&ground_id=1",
      "expectedStatus": 200,
      "expectedBody": {"ground_id": 1},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get materials invalid ground",
      "method": "GET",
      "path": "/?action=get_materials&ground_id=99",
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get archive without auth",
      "method": "GET",
      "path": "/?action=get_archive",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Start ground without auth",
      "method": "POST",
      "path": "/?action=start_ground",
      "body": {"ground_id": 1},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Save material no auth returns 401",
      "method": "POST",
      "path": "/?action=save_material",
      "body": {"ground_id": 1, "type": "video", "title": "Test"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}