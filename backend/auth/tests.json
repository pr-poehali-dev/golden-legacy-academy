{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/?action=register",
      "body": {"name": "Тест Пользователь", "email": "test_academy_777@example.com", "password": "password123"},
      "expectedStatus": 201,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login existing user",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_academy_777@example.com", "password": "password123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_academy_777@example.com", "password": "wrong"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Profile without token",
      "method": "GET",
      "path": "/?action=profile",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Update profile without token",
      "method": "POST",
      "path": "/?action=update_profile",
      "body": {"name": "Test"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Change password without token",
      "method": "POST",
      "path": "/?action=change_password",
      "body": {"current_password": "old", "new_password": "new123", "confirm_password": "new123"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}